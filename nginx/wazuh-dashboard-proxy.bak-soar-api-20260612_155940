server {
    listen 443 ssl;
    server_name wazuh-manager-hmg.tre-pr.jus.br;

    ssl_certificate     /etc/wazuh-dashboard/certs/dashboard.pem;
    ssl_certificate_key /etc/wazuh-dashboard/certs/dashboard-key.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    client_max_body_size 50M;

    # ==========================
    # HMG Wazuh SOAR em /soar/
    # ==========================
    location = /soar {
        return 301 /soar/;
    }

    location ^~ /soar/data/ {
        alias /var/www/wazuh-soar/data/;
        auth_basic "HMG SOAR - Acesso Restrito";
        auth_basic_user_file /etc/nginx/.htpasswd-wazuh-soar;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
        try_files $uri =404;
    }

    location ^~ /soar/reports/ {
        alias /var/www/wazuh-soar/reports/;
        auth_basic "HMG SOAR - Acesso Restrito";
        auth_basic_user_file /etc/nginx/.htpasswd-wazuh-soar;
        add_header Cache-Control "public, max-age=86400" always;
        try_files $uri =404;
    }

    location ^~ /soar/ {
        alias /var/www/wazuh-soar/;
        index index.html;
        autoindex off;

        auth_basic "HMG SOAR - Acesso Restrito";
        auth_basic_user_file /etc/nginx/.htpasswd-wazuh-soar;

        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;

        try_files $uri $uri/ /soar/index.html;
    }

    # ==========================
    # Wazuh Dashboard original
    # ==========================
    location / {
        proxy_pass https://127.0.0.1:5601;

        proxy_http_version 1.1;
        proxy_ssl_verify off;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 300;
        proxy_send_timeout 300;
        proxy_buffering off;
    }

    access_log /var/log/nginx/wazuh-dashboard-proxy-access.log;
    error_log  /var/log/nginx/wazuh-dashboard-proxy-error.log warn;
}
